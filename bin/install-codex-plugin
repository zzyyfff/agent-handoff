#!/usr/bin/env bash
# bin/install-codex-plugin
#
# Symlinks adapters/codex-cli/ to ~/.codex/plugins/agent-handoff/.
# Idempotent.

set -euo pipefail

repo_root="$(cd "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
src="$repo_root/adapters/codex-cli"
dest="$HOME/.codex/plugins/agent-handoff"

if [[ ! -d "$src" ]]; then
  printf 'error: source plugin dir missing: %s\n' "$src" >&2
  exit 1
fi

mkdir -p "$HOME/.codex/plugins"

if [[ -L "$dest" ]]; then
  current="$(readlink "$dest")"
  if [[ "$current" == "$src" ]]; then
    printf 'already installed: %s -> %s\n' "$dest" "$src"
    exit 0
  fi
  printf 'replacing stale symlink: %s (was -> %s)\n' "$dest" "$current"
  rm -- "$dest"
elif [[ -e "$dest" ]]; then
  printf 'error: %s exists and is not a symlink; refusing to clobber\n' "$dest" >&2
  exit 1
fi

ln -s "$src" "$dest"
printf 'installed: %s -> %s\n' "$dest" "$src"
